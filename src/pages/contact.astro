---
import Layout from '../layouts/Layout.astro';
---
<Layout title="Contact" description="Get in touch with Meddy Ben Ayed — founder, engineer, and builder based in Fremont, CA." canonical="/contact">

<div class="contact-page">
  <div class="section-label">CONTACT</div>
  <div class="contact-heading">
    Let's build<br/><em>something worth building.</em>
  </div>
  <div class="contact-links" style="margin-top:32px;">
    <a href="mailto:Meddybayed@gmail.com" class="contact-link">Meddybayed@gmail.com</a>
    <a href="tel:6506905743" class="contact-link">650-690-5743</a>
    <a href="https://linkedin.com/in/meddybayed" target="_blank" rel="noopener" class="contact-link">LinkedIn</a>
  </div>
</div>

</Layout>

<style>
.contact-page {
  max-width: var(--max); margin: 0 auto;
  padding: 140px 40px 100px;
  min-height: 70vh;
  display: flex; flex-direction: column; justify-content: center;
}
@media (max-width: 640px) {
  .contact-page { padding: 100px 20px 60px; min-height: 60vh; }
}
</style>
