---
import Layout from '../../layouts/Layout.astro';
import { projects } from '../../data/gallery.ts';

export function getStaticPaths() {
  return projects.map(p => ({ params: { project: p.slug } }));
}

const { project: slug } = Astro.params;
const project = projects.find(p => p.slug === slug)!;
---
<Layout title={`${project.title} — Gallery`}>

<div class="page-content">

  <!-- Header -->
  <div style="margin-bottom:48px;">
    <a href="/gallery" style="font-family:var(--font-mono);font-size:11px;letter-spacing:0.1em;color:rgba(255,255,255,0.4);display:inline-flex;align-items:center;gap:8px;margin-bottom:24px;">
      ← Back to Gallery
    </a>
    <div class="section-label">{project.slug.toUpperCase()}</div>
    <h1 style="font-family:var(--font-sans);font-size:clamp(28px,4vw,48px);font-weight:600;letter-spacing:-1px;color:var(--white);margin-bottom:12px;">{project.title}</h1>
    <p style="font-family:var(--font-body);font-size:15px;line-height:1.65;color:rgba(255,255,255,0.6);max-width:600px;">{project.description}</p>
  </div>

  <!-- Files -->
  {project.files.length === 0 ? (
    <div style="border:1px dashed rgba(255,255,255,0.1);border-radius:4px;padding:60px 40px;text-align:center;">
      <div style="font-family:var(--font-mono);font-size:11px;letter-spacing:0.14em;color:rgba(255,255,255,0.25);margin-bottom:12px;">NO FILES YET</div>
      <p style="font-family:var(--font-body);font-size:14px;color:rgba(255,255,255,0.35);">Add files to <code style="font-family:var(--font-mono);font-size:12px;background:rgba(255,255,255,0.06);padding:2px 6px;border-radius:2px;">public/gallery/{project.slug}/</code> and register them in <code style="font-family:var(--font-mono);font-size:12px;background:rgba(255,255,255,0.06);padding:2px 6px;border-radius:2px;">src/data/gallery.ts</code></p>
    </div>
  ) : (
    <div class="files-grid">
      {project.files.map(f => (
        <button class="file-tile" data-file={`/gallery/${slug}/${encodeURI(f.file)}`} data-type={f.type} data-name={f.name}>
          <div class="file-tile-preview">
            {f.type === 'image'
              ? <img src={`/gallery/${slug}/${encodeURI(f.file)}`} alt={f.name} style="width:100%;height:100%;object-fit:cover;display:block;"/>
              : f.type === 'video'
              ? <div class="video-card-preview">
                  <video src={`/gallery/${slug}/${encodeURI(f.file)}`} preload="metadata" muted playsinline></video>
                  <div class="video-play-badge">▶</div>
                </div>
              : f.type === 'stl'
              ? <div class="stl-card-preview" data-stl={`/gallery/${slug}/${encodeURI(f.file)}`}></div>
              : f.type === 'docx'
              ? <div class="docx-preview" data-docx={`/gallery/${slug}/${encodeURI(f.file)}`}>
                  <div class="docx-preview-text">Loading preview…</div>
                </div>
              : <div class="file-tile-icon">
                  {f.type === 'video' && <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><polygon points="5 3 19 12 5 21 5 3"/></svg>}
                  {f.type === 'text' && <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/></svg>}
                  {f.type === 'stl' && <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M12 2L2 7l10 5 10-5-10-5z"/><path d="M2 17l10 5 10-5"/><path d="M2 12l10 5 10-5"/></svg>}
                  {f.type === 'pdf' && <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>}
                  {f.type === 'docx' && <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/></svg>}
                  {(f.type === 'other') && <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M13 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V9z"/><polyline points="13 2 13 9 20 9"/></svg>}
                </div>
            }
          </div>
          <div class="file-tile-name">{f.name}</div>
          <div class="file-tile-type">{f.file.split('.').pop()?.toUpperCase()}</div>
        </button>
      ))}
    </div>
  )}
</div>

<!-- Modal -->
<div id="viewer-modal" class="modal-overlay" style="display:none;">
  <div class="modal-box">
    <div class="modal-header">
      <span id="modal-title" class="modal-title"></span>
      <button id="modal-close" class="modal-close">✕</button>
    </div>
    <div id="modal-body" class="modal-body"></div>
  </div>
</div>

</Layout>

<style>
.page-content {
  max-width: var(--max); margin: 0 auto;
  padding: 100px 40px 80px;
}
@media (max-width: 640px) {
  .page-content { padding: 90px 20px 60px; }
}
.files-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(160px, 1fr));
  gap: 12px;
}
@media (max-width: 640px) {
  .files-grid { grid-template-columns: repeat(2, 1fr); gap: 8px; }
  .modal-box { max-height: 95vh; }
  .modal-body iframe, #stl-canvas { height: 55vh; }
}
.file-tile {
  border: 1px solid rgba(255,255,255,0.08);
  border-radius: 4px;
  overflow: hidden;
  display: flex; flex-direction: column;
  cursor: pointer; background: none;
  transition: border-color 0.2s, background 0.2s;
  width: 100%; text-align: left;
}
.file-tile:hover {
  border-color: rgba(255,255,255,0.22);
  background: rgba(255,255,255,0.02);
}
.file-tile-preview {
  width: 100%; aspect-ratio: 16/9;
  background: #0a0a0a;
  display: flex; align-items: center; justify-content: center;
  overflow: hidden; flex-shrink: 0;
}
.file-tile-icon {
  width: 36px; height: 36px; color: rgba(255,255,255,0.25);
}
.file-tile-icon svg { width: 100%; height: 100%; }
.video-card-preview {
  width: 100%; height: 100%; position: relative;
  background: #0a0a0a;
  display: flex; align-items: center; justify-content: center;
}
.video-card-preview video {
  width: 100%; height: 100%; object-fit: cover; display: block;
}
.video-play-badge {
  position: absolute; inset: 0;
  display: flex; align-items: center; justify-content: center;
  font-size: 18px; color: rgba(255,255,255,0.8);
  pointer-events: none;
  text-shadow: 0 1px 4px rgba(0,0,0,0.6);
}
.stl-card-preview {
  width: 100%; height: 100%;
  background: #0a0a0a;
}
.stl-card-preview canvas { display: block; width: 100%; height: 100%; }
.docx-preview {
  width: 100%; height: 100%; padding: 12px;
  background: #0f0f0f;
  overflow: hidden; position: relative;
  display: flex; align-items: flex-start;
}
.docx-preview-text {
  font-family: Georgia, serif; font-size: 8px;
  line-height: 1.4; color: rgba(255,255,255,0.55);
  overflow: hidden;
  display: -webkit-box;
  -webkit-line-clamp: 10;
  -webkit-box-orient: vertical;
}
.docx-preview-text h1, .docx-preview-text h2, .docx-preview-text h3 { font-size: 9px; font-weight: bold; color: rgba(255,255,255,0.7); margin-bottom: 2px; }
.docx-preview-text p { margin-bottom: 2px; }
.docx-preview::after {
  content: ''; position: absolute; left: 0; right: 0; bottom: 0; height: 30%;
  background: linear-gradient(to bottom, transparent, #0f0f0f);
  pointer-events: none;
}
.file-tile-name {
  font-family: var(--font-body); font-size: 13px;
  color: var(--white); line-height: 1.4;
  padding: 10px 12px 4px;
}
.file-tile-type {
  font-family: var(--font-mono); font-size: 10px;
  letter-spacing: 0.1em; color: rgba(255,255,255,0.3);
  padding: 0 12px 12px;
}

/* Modal */
.modal-overlay {
  position: fixed; inset: 0; z-index: 99999;
  background: rgba(0,0,0,0.85);
  backdrop-filter: blur(8px);
  display: flex; align-items: center; justify-content: center;
  padding: 24px;
}
.modal-box {
  background: #0d0d0d;
  border: 1px solid rgba(255,255,255,0.1);
  border-radius: 6px;
  width: 100%; max-width: 900px;
  max-height: 90vh;
  display: flex; flex-direction: column;
  overflow: hidden;
}
.modal-header {
  display: flex; align-items: center; justify-content: space-between;
  padding: 16px 20px;
  border-bottom: 1px solid rgba(255,255,255,0.07);
  flex-shrink: 0;
}
.modal-title {
  font-family: var(--font-mono); font-size: 12px;
  letter-spacing: 0.08em; color: rgba(255,255,255,0.7);
}
.modal-close {
  font-family: var(--font-mono); font-size: 14px;
  color: rgba(255,255,255,0.4); cursor: pointer;
  background: none; border: none;
  transition: color 0.15s;
}
.modal-close:hover { color: var(--white); }
.modal-body {
  flex: 1; overflow: auto;
  display: flex; align-items: center; justify-content: center;
}
.modal-body img {
  max-width: 100%; max-height: 75vh;
  object-fit: contain; display: block;
}
.modal-body pre {
  padding: 24px; font-family: var(--font-mono); font-size: 13px;
  line-height: 1.7; color: rgba(255,255,255,0.8);
  white-space: pre-wrap; word-break: break-word;
  width: 100%;
}
.modal-body iframe {
  width: 100%; height: 75vh; border: none;
}
#stl-canvas { width: 100%; height: 75vh; display: block; }
.modal-download {
  display: flex; flex-direction: column; align-items: center; gap: 16px;
  padding: 48px;
  font-family: var(--font-body); color: rgba(255,255,255,0.5);
}
.modal-download a {
  font-family: var(--font-mono); font-size: 12px;
  letter-spacing: 0.08em; color: var(--white);
  border: 1px solid rgba(255,255,255,0.2);
  padding: 10px 20px; border-radius: 3px;
  transition: background 0.2s;
}
.modal-download a:hover { background: rgba(255,255,255,0.06); }
</style>

<script is:inline>
// ─── Video card first-frame previews ───
document.querySelectorAll('.video-card-preview video').forEach(v => {
  v.addEventListener('loadedmetadata', () => { v.currentTime = 0.1; });
});

// ─── DOCX card previews ───
function loadMammothScript() {
  return new Promise((resolve, reject) => {
    if (window.mammoth) { resolve(); return; }
    const s = document.createElement('script');
    s.src = 'https://cdn.jsdelivr.net/npm/mammoth@1.8.0/mammoth.browser.min.js';
    s.onload = resolve;
    s.onerror = reject;
    document.head.appendChild(s);
  });
}

const docxPreviews = document.querySelectorAll('.docx-preview');
if (docxPreviews.length > 0) {
  loadMammothScript().then(() => {
    docxPreviews.forEach(el => {
      const url = el.dataset.docx;
      const textEl = el.querySelector('.docx-preview-text');
      fetch(url)
        .then(r => r.arrayBuffer())
        .then(buf => window.mammoth.convertToHtml({ arrayBuffer: buf }))
        .then(result => { textEl.innerHTML = result.value; })
        .catch(() => { textEl.textContent = 'Preview unavailable'; });
    });
  }).catch(() => {
    docxPreviews.forEach(el => {
      el.querySelector('.docx-preview-text').textContent = 'Document';
    });
  });
}

// ─── STL card previews ───
const stlPreviews = document.querySelectorAll('.stl-card-preview');
if (stlPreviews.length > 0) {
  Promise.all([
    import('https://esm.sh/three@0.176.0'),
    import('https://esm.sh/three@0.176.0/examples/jsm/loaders/STLLoader'),
  ]).then(([THREE, { STLLoader }]) => {
    stlPreviews.forEach(el => {
      const url = el.dataset.stl;
      const canvas = document.createElement('canvas');
      el.appendChild(canvas);
      setTimeout(() => {
        const w = el.offsetWidth || 180;
        const h = el.offsetHeight || 101;
        canvas.width = w; canvas.height = h;

        const renderer = new THREE.WebGLRenderer({ canvas, antialias: true, alpha: true });
        renderer.setSize(w, h);
        renderer.setPixelRatio(Math.min(window.devicePixelRatio, 2));
        renderer.setClearColor(0x0a0a0a);

        const scene = new THREE.Scene();
        const camera = new THREE.PerspectiveCamera(45, w / h, 0.1, 10000);

        scene.add(new THREE.AmbientLight(0xffffff, 0.5));
        const d1 = new THREE.DirectionalLight(0xffffff, 0.9);
        d1.position.set(1, 2, 3); scene.add(d1);
        const d2 = new THREE.DirectionalLight(0xffffff, 0.3);
        d2.position.set(-1, -1, -1); scene.add(d2);

        new STLLoader().load(url, geo => {
          geo.computeBoundingBox();
          const center = new THREE.Vector3();
          geo.boundingBox.getCenter(center);
          geo.translate(-center.x, -center.y, -center.z);
          const size = new THREE.Vector3();
          geo.boundingBox.getSize(size);
          const maxDim = Math.max(size.x, size.y, size.z);
          const dist = maxDim * 2;
          camera.position.set(dist, maxDim * 0.6, dist);
          camera.lookAt(0, 0, 0);

          scene.add(new THREE.Mesh(geo, new THREE.MeshPhongMaterial({ color: 0xcccccc, specular: 0x444444, shininess: 50 })));

          let angle = Math.atan2(dist, dist);
          (function animate() {
            requestAnimationFrame(animate);
            angle += 0.008;
            camera.position.x = Math.sin(angle) * dist;
            camera.position.z = Math.cos(angle) * dist;
            camera.lookAt(0, 0, 0);
            renderer.render(scene, camera);
          })();
        });
      }, 80);
    });
  }).catch(() => {});
}

const modal = document.getElementById('viewer-modal');
const modalTitle = document.getElementById('modal-title');
const modalBody = document.getElementById('modal-body');
const modalClose = document.getElementById('modal-close');

let stopAnim = null;

function closeModal() {
  if (stopAnim) { stopAnim(); stopAnim = null; }
  modal.style.display = 'none';
  modalBody.innerHTML = '';
  modalBody.style.alignItems = 'center';
  modalBody.style.padding = '';
}

modalClose.addEventListener('click', closeModal);
modal.addEventListener('click', (e) => { if (e.target === modal) closeModal(); });
document.addEventListener('keydown', (e) => { if (e.key === 'Escape') closeModal(); });

function loadMammoth() {
  return new Promise((resolve, reject) => {
    if (window.mammoth) { resolve(); return; }
    const s = document.createElement('script');
    s.src = 'https://cdn.jsdelivr.net/npm/mammoth@1.8.0/mammoth.browser.min.js';
    s.onload = resolve;
    s.onerror = reject;
    document.head.appendChild(s);
  });
}

document.querySelectorAll('.file-tile').forEach(tile => {
  tile.addEventListener('click', () => {
    const url = tile.dataset.file;
    const type = tile.dataset.type;
    const name = tile.dataset.name;

    modalTitle.textContent = name;
    modalBody.innerHTML = '';
    modalBody.style.alignItems = 'center';
    modalBody.style.padding = '';
    modal.style.display = 'flex';

    if (type === 'image') {
      const img = document.createElement('img');
      img.style.cssText = 'max-width:100%;max-height:75vh;object-fit:contain;display:block;';
      img.onerror = () => {
        img.replaceWith(Object.assign(document.createElement('p'), {
          textContent: 'Failed to load image.',
          style: 'padding:24px;font-family:monospace;font-size:12px;color:rgba(255,80,80,0.7);'
        }));
      };
      img.src = url;
      img.alt = name;
      modalBody.appendChild(img);

    } else if (type === 'text') {
      const pre = document.createElement('pre');
      pre.style.cssText = 'padding:24px;font-family:monospace;font-size:13px;line-height:1.7;color:rgba(255,255,255,0.85);white-space:pre-wrap;word-break:break-word;width:100%;';
      pre.textContent = 'Loading…';
      modalBody.appendChild(pre);
      fetch(url).then(r => r.text()).then(t => { pre.textContent = t; }).catch(() => { pre.textContent = 'Failed to load.'; });

    } else if (type === 'video') {
      const video = document.createElement('video');
      video.style.cssText = 'max-width:100%;max-height:75vh;display:block;outline:none;';
      video.controls = true;
      video.src = url;
      modalBody.appendChild(video);

    } else if (type === 'pdf') {
      const iframe = document.createElement('iframe');
      iframe.style.cssText = 'width:100%;height:75vh;border:none;';
      iframe.src = url;
      modalBody.appendChild(iframe);

    } else if (type === 'docx') {
      const wrapper = document.createElement('div');
      wrapper.style.cssText = 'padding:32px 40px;max-width:720px;margin:0 auto;color:rgba(255,255,255,0.88);font-family:Georgia,serif;line-height:1.8;font-size:15px;width:100%;';
      wrapper.textContent = 'Loading document…';
      modalBody.style.alignItems = 'flex-start';
      modalBody.appendChild(wrapper);

      loadMammoth()
        .then(() => fetch(url))
        .then(r => r.arrayBuffer())
        .then(buf => window.mammoth.convertToHtml({ arrayBuffer: buf }))
        .then(result => { wrapper.innerHTML = result.value; })
        .catch(() => {
          wrapper.innerHTML = `<p style="color:rgba(255,80,80,0.7);margin-bottom:12px;">Could not render document.</p><a href="${url}" download style="font-family:monospace;font-size:12px;color:rgba(255,255,255,0.7);border-bottom:1px solid rgba(255,255,255,0.3);">Download instead</a>`;
        });

    } else if (type === 'stl') {
      const container = document.createElement('div');
      container.style.cssText = 'width:100%;height:75vh;position:relative;display:flex;align-items:center;justify-content:center;';
      const loading = document.createElement('p');
      loading.style.cssText = 'font-family:monospace;font-size:12px;color:rgba(255,255,255,0.35);';
      loading.textContent = 'Loading 3D model…';
      container.appendChild(loading);
      modalBody.style.padding = '0';
      modalBody.appendChild(container);

      Promise.all([
        import('https://esm.sh/three@0.176.0'),
        import('https://esm.sh/three@0.176.0/examples/jsm/loaders/STLLoader'),
        import('https://esm.sh/three@0.176.0/examples/jsm/controls/OrbitControls'),
      ]).then(([THREE, { STLLoader }, { OrbitControls }]) => {
        loading.remove();
        const canvas = document.createElement('canvas');
        canvas.style.cssText = 'width:100%;height:100%;display:block;outline:none;position:absolute;inset:0;';
        container.style.position = 'relative';
        container.appendChild(canvas);

        setTimeout(() => {
          const w = container.offsetWidth || 800;
          const h = container.offsetHeight || 600;
          canvas.width = w; canvas.height = h;

          const renderer = new THREE.WebGLRenderer({ canvas, antialias: true });
          renderer.setSize(w, h);
          renderer.setPixelRatio(Math.min(window.devicePixelRatio, 2));
          renderer.setClearColor(0x0d0d0d);

          const scene = new THREE.Scene();
          const camera = new THREE.PerspectiveCamera(45, w / h, 0.1, 10000);

          scene.add(new THREE.AmbientLight(0xffffff, 0.5));
          const d1 = new THREE.DirectionalLight(0xffffff, 0.9);
          d1.position.set(1, 2, 3); scene.add(d1);
          const d2 = new THREE.DirectionalLight(0xffffff, 0.3);
          d2.position.set(-1, -1, -1); scene.add(d2);

          const controls = new OrbitControls(camera, renderer.domElement);
          controls.enableDamping = true; controls.dampingFactor = 0.08;

          new STLLoader().load(url, geo => {
            geo.computeBoundingBox();
            const center = new THREE.Vector3();
            geo.boundingBox.getCenter(center);
            geo.translate(-center.x, -center.y, -center.z);
            const size = new THREE.Vector3();
            geo.boundingBox.getSize(size);
            const maxDim = Math.max(size.x, size.y, size.z);
            camera.position.set(maxDim, maxDim * 0.8, maxDim * 2);
            controls.update();
            scene.add(new THREE.Mesh(geo, new THREE.MeshPhongMaterial({ color: 0xdddddd, specular: 0x333333, shininess: 40 })));
          }, undefined, () => {
            container.innerHTML = '<p style="padding:24px;color:rgba(255,80,80,0.7);font-family:monospace;font-size:12px;">Failed to load STL.</p>';
          });

          let running = true;
          stopAnim = () => { running = false; };
          (function animate() {
            if (!running) return;
            requestAnimationFrame(animate);
            controls.update();
            renderer.render(scene, camera);
          })();
        }, 80);
      }).catch(() => {
        container.innerHTML = '<p style="padding:24px;color:rgba(255,80,80,0.7);font-family:monospace;font-size:12px;">Could not load 3D viewer.</p>';
      });

    } else {
      modalBody.innerHTML = `<div style="display:flex;flex-direction:column;align-items:center;gap:16px;padding:48px;font-family:var(--font-body);color:rgba(255,255,255,0.5);"><span>No preview available.</span><a href="${url}" download style="font-family:monospace;font-size:12px;letter-spacing:0.08em;color:var(--white);border:1px solid rgba(255,255,255,0.2);padding:10px 20px;border-radius:3px;">Download file</a></div>`;
    }
  });
});
</script>
